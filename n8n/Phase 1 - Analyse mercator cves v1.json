    {
      "parameters": {
        "jsCode": "// Récupération du premier item\nconst item = items[0].json;\n\n// Extraction et nettoyage (trim) du modèle pour enlever l'espace\nlet nom = \"cve_actions\";\nlet rawModel = $('Definitions initiales').first().json.ollamaModel || \"\";\nlet model = rawModel.trim().replace(/\\s+/g, '_'); // On enlève les espaces et on remplace ceux du milieu par des _\n\n// --- Génération du timestamp à l'heure de Paris (Europe/Paris) ---\nconst now = new Date();\nconst options = { timeZone: 'Europe/Paris', year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false };\nconst formatter = new Intl.DateTimeFormat('fr-FR', options);\nconst partsTime = formatter.formatToParts(now);\n\n// Extraction des composants pour construire YYYYMMDD-HHMMSS\nconst t = {};\npartsTime.forEach(({type, value}) => t[type] = value);\nconst date_heure_str = `${t.year}${t.month}${t.day}-${t.hour}${t.minute}${t.second}`;\n\n// Création du nom de fichier\nconst parts = [nom, model, date_heure_str].filter(p => p !== \"\");\nconst filename = parts.join(\"_\");\n\nreturn [{\n    json: {\n        filename: filename + \".json\"\n    }\n}];"
      },
