    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.content\n\n// Étape 1 : Extraction du bloc JSON et suppression des délimiteurs (inchangé)\nconst match = raw.match(/```json\\s*([\\s\\S]*?)```/);\n\nlet cleaned;\n\nif (match && match[1]) {\n    cleaned = match[1].trim();\n} else {\n    cleaned = raw.replace(/^```json/, '').replace(/```$/, '').trim();\n}\n\n// -------------------------------------------------------------------\n// Étape 2 : NETTOYAGE EXTRÊME ET CIBLÉ (V5.0)\n// -------------------------------------------------------------------\n\n// 2a. Suppression des caractères de contrôle invisibles et des séparateurs.\n// (Gère \\u200b, \\uFEFF et autres plages de contrôle)\ncleaned = cleaned.replace(/[\\u0000-\\u001F\\u007F-\\u009F\\u2000-\\u200F\\u2028-\\u202F\\u200b\\uFEFF]/g, '');\n\n// 2b. CIBLAGE ET SUPPRESSION SPÉCIFIQUE DU CARACTÈRE '<ctrl46>' (\\u5E7B)\n// Nous utilisons le code Unicode pour forcer la suppression même si la regex précédente échoue.\n// Cette ligne devrait éliminer tous les '<ctrl46>' restants.\ncleaned = cleaned.replace(/\\u5E7B/g, ''); \n\n// 2c. FILTRE ADDITIONNEL : Supprimer TOUS les caractères non-ASCII qui ne sont pas des lettres françaises\n// Caractères > U+00FF non répertoriés sont supprimés. Ce filtre devrait attraper d'autres caractères exotiques.\n//cleaned = cleaned.replace(/[^\\u0000-\\u007F\\u00C0-\\u00FF]/g, ''); \n\n// 2d. Correction des sauts de ligne/retours chariot NON ÉCHAPPÉS.\n// Remplacement par \\n échappé pour rendre le JSON valide.\ncleaned = cleaned.replace(/\\r?\\n|\\r/g, '\\\\n'); \n\n// -------------------------------------------------------------------\n// Étape 3 : PARSING SÉCURISÉ\n// -------------------------------------------------------------------\n\nlet corrected = cleaned; // Déclaré pour la portée du catch\n\ntry {\n    // 3a. Correction des virgules orphelines (ex: {\"a\": 1,})\n    corrected = cleaned.replace(/,\\s*([}\\]])/g, '$1');\n    \n    const parsed = JSON.parse(corrected);\n    return [{ json: parsed }];\n} catch (e) {\n    // Renvoyer l'erreur avec le contenu nettoyé qui a échoué\n    return [{ json: { error: \"JSON parsing failed\", details: e.message, contentAttempt: corrected } }];\n}"
      },
